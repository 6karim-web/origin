<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/terminal_bg"
    android:padding="12dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="&#8383; BITCOIN HUNT"
        android:textColor="@color/terminal_orange"
        android:textSize="20sp"
        android:fontFamily="monospace"
        android:textStyle="bold"
        android:gravity="center"
        android:paddingTop="8dp"
        android:paddingBottom="4dp"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="----------------------------------------"
        android:textColor="@color/terminal_dim_green"
        android:fontFamily="monospace"
        android:textSize="10sp"
        android:gravity="center"
        android:paddingBottom="8dp"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="&gt; TARGET_ADDRESS:"
        android:textColor="@color/terminal_green"
        android:fontFamily="monospace"
        android:textSize="12sp"
        android:paddingBottom="4dp"/>

    <EditText
        android:id="@+id/editTargetAddress"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="@string/hint_target_address"
        android:textColor="@color/terminal_green"
        android:textColorHint="@color/terminal_dim_green"
        android:background="@color/terminal_input_bg"
        android:fontFamily="monospace"
        android:textSize="13sp"
        android:padding="10dp"
        android:inputType="text"
        android:singleLine="true"
        android:imeOptions="actionDone"
        android:layout_marginBottom="12dp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="10dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:background="@color/terminal_input_bg"
            android:padding="10dp"
            android:layout_marginEnd="6dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="KEYS/SEC"
                android:textColor="@color/terminal_orange"
                android:fontFamily="monospace"
                android:textSize="10sp"/>

            <TextView
                android:id="@+id/tvKeysPerSec"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textColor="@color/terminal_green"
                android:fontFamily="monospace"
                android:textSize="22sp"
                android:textStyle="bold"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:background="@color/terminal_input_bg"
            android:padding="10dp"
            android:layout_marginStart="6dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="TOTAL KEYS"
                android:textColor="@color/terminal_orange"
                android:fontFamily="monospace"
                android:textSize="10sp"/>

            <TextView
                android:id="@+id/tvTotalKeys"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textColor="@color/terminal_green"
                android:fontFamily="monospace"
                android:textSize="22sp"
                android:textStyle="bold"/>
        </LinearLayout>

    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="10dp">

        <Button
            android:id="@+id/btnStart"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:text="@string/btn_start"
            android:textColor="@color/terminal_green"
            android:fontFamily="monospace"
            android:textSize="12sp"
            android:textStyle="bold"
            android:background="@color/terminal_button_bg"
            android:layout_marginEnd="6dp"/>

        <Button
            android:id="@+id/btnStop"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:text="@string/btn_stop"
            android:textColor="@color/terminal_stop_text"
            android:fontFamily="monospace"
            android:textSize="12sp"
            android:textStyle="bold"
            android:background="@color/terminal_stop_bg"
            android:enabled="false"
            android:layout_marginStart="6dp"/>

    </LinearLayout>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="&gt; CONSOLE OUTPUT:"
        android:textColor="@color/terminal_green"
        android:fontFamily="monospace"
        android:textSize="12sp"
        android:paddingBottom="4dp"/>

    <ScrollView
        android:id="@+id/scrollConsole"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="@color/terminal_input_bg"
        android:padding="8dp">

        <TextView
            android:id="@+id/tvConsole"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/console_ready"
            android:textColor="@color/terminal_green"
            android:fontFamily="monospace"
            android:textSize="11sp"
            android:lineSpacingMultiplier="1.3"/>

    </ScrollView>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="[ ECKey generation speed test ]"
        android:textColor="@color/terminal_dim_green"
        android:fontFamily="monospace"
        android:textSize="10sp"
        android:gravity="center"
        android:paddingTop="6dp"
        android:paddingBottom="2dp"/>

</LinearLayout>
